# ── Backend (Python scripts: publish-article.py, test_pipeline.py) ────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key      # full DB access — keep secret

# ── Edge Functions (Deno, set via `supabase secrets set`) ─────────────────────
# SUPABASE_URL above is reused
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key  # same value as SUPABASE_SERVICE_KEY
OPENROUTER_API_KEY=your-openrouter-api-key
# Optional — defaults to poolside/laguna-xs-2.1:free
# OPENROUTER_MODEL=poolside/laguna-xs-2.1:free
